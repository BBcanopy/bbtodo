# The port you would like to expose
CLIENT_PORT=8080

# Your public facing URL
CLIENT_URL=http://localhost:8080

SESSION_SECRET=replace-with-a-32-character-secret-minimum

# OIDC Config
OIDC_ISSUER=https://your-issuer.example.com
OIDC_CLIENT_ID=bbtodo
OIDC_CLIENT_SECRET=replace-with-your-client-secret
OIDC_SCOPES=openid profile email

# Optional, but recommended
BBTODO_UID=1000
BBTODO_GID=1000

# You don't need these if you run all-in-one image
API_ORIGIN=http://localhost:3000
SERVER_PORT=3000